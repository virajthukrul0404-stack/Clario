# Database (Supabase or any PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/post-auth
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/post-auth

# Socket server
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
SOCKET_SERVER_INTERNAL_URL=http://localhost:4000

# Pusher realtime signaling (optional if using socket fallback)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
PUSHER_APP_ID=
PUSHER_SECRET=

# WebRTC TURN / ICE (optional but recommended for production)
METERED_DOMAIN=
METERED_SECRET_KEY=
TURN_SERVER_URL=
TURN_SERVER_URLS=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=
NEXT_PUBLIC_TURN_SERVER_URL=
NEXT_PUBLIC_TURN_SERVER_URLS=
NEXT_PUBLIC_TURN_SERVER_USERNAME=
NEXT_PUBLIC_TURN_SERVER_CREDENTIAL=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (optional)
SENTRY_DSN=
